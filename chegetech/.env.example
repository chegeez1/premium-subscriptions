# =============================================================
#  CHEGE TECH — Environment Variables
#  Fill in your values, then add each one in Render:
#  Dashboard → Your Service → Environment → Add Environment Variable
# =============================================================

# ── Admin Login ───────────────────────────────────────────────
# The email and password you use to log in to /admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Paystack Payments ─────────────────────────────────────────
# Get these from https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_PUBLIC_KEY=pk_live_
PAYSTACK_SECRET_KEY=sk_live_

# ── Email (Gmail SMTP) ────────────────────────────────────────
# Use your Gmail address + an App Password (NOT your normal password)
# Create App Password: Google Account → Security → 2FA → App Passwords
EMAIL_USER=your@gmail.com
EMAIL_PASS=

# ── Telegram Bot (optional) ───────────────────────────────────
# Create a bot via @BotFather on Telegram → copy the token
# Get Chat ID: message @userinfobot in your channel/group
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── OpenAI AI Assistant (optional) ───────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Database (leave blank to use built-in SQLite) ─────────────
# Only fill this if you have an external PostgreSQL database
EXTERNAL_DATABASE_URL=

# ── App Config ────────────────────────────────────────────────
SITE_NAME=Chege Tech
SUPPORT_EMAIL=support@chegetech.com
WHATSAPP_NUMBER=+254114291301
WHATSAPP_CHANNEL=https://whatsapp.com/channel/0029VbBx7NeDp2QGF7qoZ02A
CUSTOM_DOMAIN=
